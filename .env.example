# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Resolve satellite ingest token
# Get this from: https://app.dev0.resolve.ai → Settings → Satellites
RESOLVE_INGEST_TOKEN=your-token-here

# Alert notifications. Slack and Teams coexist — set either, both, or neither.
# Slack: an Incoming Webhook URL (https://hooks.slack.com/services/...)
SLACK_WEBHOOK_URL=

# Teams: an Incoming Webhook or Power Automate (Workflows) URL.
# Leave blank to use the built-in mock Teams channel view at http://localhost:30150
TEAMS_WEBHOOK_URL=
