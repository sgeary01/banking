{
  "title": "Banking — Traces & Service Map",
  "uid": "banking-traces",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["banking", "tracing"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
        "query": "label_values(traces_spanmetrics_calls_total, service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": {},
        "hide": 0,
        "multi": false,
        "options": [],
        "sort": 1
      },
      {
        "name": "min_duration",
        "label": "Min Duration (ms)",
        "type": "custom",
        "query": "0,10,50,100,250,500",
        "current": { "value": "0", "text": "0" },
        "options": [
          { "value": "0", "text": "0", "selected": true },
          { "value": "10ms", "text": "10" },
          { "value": "50ms", "text": "50" },
          { "value": "100ms", "text": "100" },
          { "value": "250ms", "text": "250" },
          { "value": "500ms", "text": "500" }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Map",
      "type": "nodeGraph",
      "gridPos": { "x": 0, "y": 0, "w": 14, "h": 12 },
      "datasource": { "type": "tempo", "uid": "banking-tempo" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "banking-tempo" },
          "queryType": "serviceMap",
          "serviceMapQuery": "{}"
        }
      ],
      "options": {
        "nodes": {},
        "edges": {}
      }
    },
    {
      "id": 2,
      "title": "Request Rate by Service (traces/min)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[2m]) * 60",
          "legendFormat": "{{service}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "title": "P99 Latency by Service (from spans)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 6, "w": 10, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.99, rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_SERVER\"}[2m]))",
          "legendFormat": "p99 {{service}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "title": "Trace Explorer",
      "type": "table",
      "description": "Recent traces — click a Trace ID to open in Tempo",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "datasource": { "type": "tempo", "uid": "banking-tempo" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "banking-tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"$service\" }",
          "limit": 50,
          "tableType": "traces"
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": [
              { "desc": true, "displayName": "Start time" }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open trace",
                    "url": "/explore?left=%7B%22datasource%22%3A%22banking-tempo%22%2C%22queries%22%3A%5B%7B%22query%22%3A%22${__value.raw}%22%2C%22queryType%22%3A%22traceId%22%7D%5D%7D",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 100 },
                    { "color": "red", "value": 500 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "Span Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\", span_kind=\"SPAN_KIND_SERVER\"}[2m]) / rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[2m])",
          "legendFormat": "{{service}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "title": "Trace Duration Distribution (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_SERVER\"}[2m])) by (le))",
          "legendFormat": "p50",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_SERVER\"}[2m])) by (le))",
          "legendFormat": "p95",
          "instant": false,
          "range": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_SERVER\"}[2m])) by (le))",
          "legendFormat": "p99",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
