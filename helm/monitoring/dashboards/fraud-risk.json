{
  "uid": "banking-fraud",
  "title": "Banking — Fraud & Risk",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Stats",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Fraud Check RPS",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"fraud-service\"}[1m]))",
          "legendFormat": "Fraud Check RPS"
        }
      ]
    },
    {
      "id": 3,
      "title": "Fraud Service Error Rate %",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "100 * sum(rate(http_requests_total{job=\"fraud-service\", status=\"5xx\"}[1m])) / sum(rate(http_requests_total{job=\"fraud-service\"}[1m]))",
          "legendFormat": "Error Rate %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Fraud Service P95 Latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fraud-service\"}[1m])) by (le))",
          "legendFormat": "P95 Latency"
        }
      ]
    },
    {
      "id": 10,
      "title": "Fraud Activity",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Fraud Service — Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"fraud-service\", status=\"2xx\"}[1m]))",
          "legendFormat": "2xx (checks passed)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"fraud-service\", status=\"5xx\"}[1m]))",
          "legendFormat": "5xx (errors)"
        }
      ]
    },
    {
      "id": 12,
      "title": "Fraud Service — Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"fraud-service\"}[1m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fraud-service\"}[1m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 20,
      "title": "High-Value Signal",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Fraud Check Rate vs Alert Threshold",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Alert Threshold (0.5 req/s)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"fraud-service\", status=\"2xx\"}[1m]))",
          "legendFormat": "Fraud Check Rate (2xx)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "vector(0.5)",
          "legendFormat": "Alert Threshold (0.5 req/s)"
        }
      ]
    },
    {
      "id": 30,
      "title": "Reporting",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Reporting Service — Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"reporting-service\"}[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 32,
      "title": "Reporting Service — Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"reporting-service\"}[1m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"reporting-service\"}[1m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 40,
      "title": "Logs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 41,
      "title": "Fraud & Reporting Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "banking-loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "banking-loki" },
          "expr": "{namespace=\"banking\", service=~\"fraud-service|reporting-service\"} | json",
          "legendFormat": ""
        }
      ]
    }
  ],
  "tags": ["banking", "fraud", "risk"],
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "weekStart": ""
}
