{
  "uid": "banking-transactions",
  "title": "Banking — Transactions & Payments",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Volume",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Transaction RPS",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"transaction-service\"}[1m]))",
          "legendFormat": "Transaction RPS"
        }
      ]
    },
    {
      "id": 3,
      "title": "Transaction Error Rate %",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "100 * sum(rate(http_requests_total{job=\"transaction-service\", status=\"5xx\"}[1m])) / sum(rate(http_requests_total{job=\"transaction-service\"}[1m]))",
          "legendFormat": "Error Rate %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Transaction P95 Latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"transaction-service\"}[1m])) by (le))",
          "legendFormat": "P95 Latency"
        }
      ]
    },
    {
      "id": 10,
      "title": "Transaction Service",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Transaction Service — Request Rate by Status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"transaction-service\", status=\"2xx\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"transaction-service\", status=\"4xx\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"transaction-service\", status=\"5xx\"}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 12,
      "title": "Transaction Service — Latency Percentiles",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"transaction-service\"}[1m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"transaction-service\"}[1m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"transaction-service\"}[1m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 20,
      "title": "Ledger Service",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Ledger Service — Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"ledger-service\", status=\"2xx\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"ledger-service\", status=\"5xx\"}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 22,
      "title": "Ledger Service — Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"ledger-service\"}[1m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ledger-service\"}[1m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 30,
      "title": "Errors",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Transaction & Ledger Error Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "banking-loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "banking-loki" },
          "expr": "{namespace=\"banking\", service=~\"transaction-service|ledger-service\"} | json | level=\"error\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "tags": ["banking", "transactions"],
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "weekStart": ""
}
