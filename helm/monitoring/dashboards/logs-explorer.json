{
  "uid": "banking-logs",
  "title": "Atlas Financial \u2014 Logs Explorer",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "loki",
          "uid": "banking-loki"
        },
        "query": {
          "label": "service",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "{namespace=\"banking\"}",
          "type": 1
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1,
        "definition": "label_values(service)"
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Log Level",
        "query": "All,error,warning,info",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "error",
            "value": "error"
          },
          {
            "selected": false,
            "text": "warning",
            "value": "warning"
          },
          {
            "selected": false,
            "text": "info",
            "value": "info"
          }
        ],
        "multi": false,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Volume",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Log Volume per Service (per minute)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "banking-loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "banking-loki"
          },
          "expr": "sum by (service) (count_over_time({namespace=\"banking\", service=~\"$service\"} | __error__=\"\" [1m]))",
          "legendFormat": "{{service}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 10,
      "title": "Error Volume",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Warning & Error Log Rate per Service",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "banking-loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "banking-loki"
          },
          "expr": "sum by (service) (count_over_time({namespace=\"banking\", service=~\"$service\", level=~\"warning|error\"} | __error__=\"\" [1m]))",
          "legendFormat": "{{service}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 20,
      "title": "Logs",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Log Stream",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "banking-loki"
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "banking-loki"
          },
          "expr": "{namespace=\"banking\", service=~\"$service\"} | level =~ \"$level\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "tags": [
    "banking",
    "logs"
  ],
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "weekStart": ""
}
