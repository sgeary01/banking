{
  "uid": "banking-overview",
  "title": "Atlas Financial — Coverage Overview",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Services Up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 10 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "count(up{job=~\"api-gateway|auth-service|customer-service|account-service|transaction-service|ledger-service|fraud-service|notification-service|reporting-service|chaos-service\"} == 1)",
          "legendFormat": "Services Up"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total RPS",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=~\"api-gateway|auth-service|customer-service|account-service|transaction-service|ledger-service|fraud-service|notification-service|reporting-service|chaos-service\"}[1m]))",
          "legendFormat": "Total RPS"
        }
      ]
    },
    {
      "id": 4,
      "title": "Overall Error Rate %",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "100 * sum(rate(http_requests_total{job=~\"api-gateway|auth-service|customer-service|account-service|transaction-service|ledger-service|fraud-service|notification-service|reporting-service|chaos-service\", status=\"5xx\"}[1m])) / sum(rate(http_requests_total{job=~\"api-gateway|auth-service|customer-service|account-service|transaction-service|ledger-service|fraud-service|notification-service|reporting-service|chaos-service\"}[1m]))",
          "legendFormat": "Error Rate %"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Alerts",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "Firing Alerts"
        }
      ]
    },
    {
      "id": 10,
      "title": "Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Requests/sec per Service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "sum(rate(http_requests_total{job=~\"api-gateway|auth-service|customer-service|account-service|transaction-service|ledger-service|fraud-service|notification-service|reporting-service|chaos-service\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Error Rate % per Service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "100 * sum(rate(http_requests_total{job=~\"api-gateway|auth-service|customer-service|account-service|transaction-service|ledger-service|fraud-service|notification-service|reporting-service|chaos-service\", status=\"5xx\"}[1m])) by (job) / sum(rate(http_requests_total{job=~\"api-gateway|auth-service|customer-service|account-service|transaction-service|ledger-service|fraud-service|notification-service|reporting-service|chaos-service\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 20,
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "P95 Latency per Service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "banking-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"api-gateway|auth-service|customer-service|account-service|transaction-service|ledger-service|fraud-service|notification-service|reporting-service|chaos-service\"}[1m])) by (job, le))",
          "legendFormat": "{{job}} p95"
        }
      ]
    },
    {
      "id": 30,
      "title": "Logs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Recent Errors",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "banking-loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "banking-loki" },
          "expr": "{namespace=\"banking\"} | json | level=\"error\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "tags": ["banking", "overview"],
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "weekStart": ""
}
