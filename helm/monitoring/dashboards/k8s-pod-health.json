{
  "title": "Atlas Financial \u2014 Kubernetes & Pod Health",
  "uid": "banking-k8s",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "tags": [
    "banking",
    "kubernetes"
  ],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "custom",
        "query": "banking,monitoring,default",
        "current": {
          "value": "banking",
          "text": "banking"
        },
        "options": [
          {
            "value": "banking",
            "text": "banking",
            "selected": true
          },
          {
            "value": "monitoring",
            "text": "monitoring"
          },
          {
            "value": "default",
            "text": "default"
          }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pods Running",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_phase{namespace=\"$namespace\", phase=\"Running\"} == 1)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Pods Not Running",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_phase{namespace=\"$namespace\", phase!=\"Running\", phase!=\"Succeeded\"} == 1) or vector(0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "Total Restarts (1h)",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[1h]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "Node CPU Usage",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "title": "Node Memory Usage",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "Deployments Ready",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_deployment_status_replicas_available{namespace=\"$namespace\"}) / sum(kube_deployment_spec_replicas{namespace=\"$namespace\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 1.0
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 7,
      "title": "Deployment Status \u2014 Desired vs Available",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "desired",
          "expr": "kube_deployment_spec_replicas{namespace=\"$namespace\"}",
          "instant": true,
          "legendFormat": "{{deployment}}"
        },
        {
          "refId": "available",
          "expr": "kube_deployment_status_replicas_available{namespace=\"$namespace\"}",
          "instant": true,
          "legendFormat": "{{deployment}}"
        },
        {
          "refId": "unavailable",
          "expr": "kube_deployment_status_replicas_unavailable{namespace=\"$namespace\"}",
          "instant": true,
          "legendFormat": "{{deployment}}"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "valueLabel": "deployment"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "deployment": "Deployment",
              "Value #desired": "Desired",
              "Value #available": "Available",
              "Value #unavailable": "Unavailable"
            },
            "excludeByName": {
              "Time": true
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "displayName": "Deployment",
                "desc": false
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Available"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Unavailable"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 8,
      "title": "Container Restarts \u2014 Last 1h",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(sum by (pod, container) (increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[1h])))",
          "instant": true,
          "legendFormat": "{{pod}}"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "valueLabel": "pod"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "pod": "Pod",
              "container": "Container",
              "Value": "Restarts (1h)"
            },
            "excludeByName": {
              "Time": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Restarts (1h)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 3
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 9,
      "title": "Node CPU Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m]))",
          "legendFormat": "cpu usage",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 10,
      "title": "Node Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "used",
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "used",
          "instant": false,
          "range": true
        },
        {
          "refId": "total",
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "total",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "total"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "gray",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    8,
                    4
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "used"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 11,
      "title": "Pod Restart Rate",
      "type": "timeseries",
      "description": "Container restart rate over time \u2014 spikes indicate crash loops",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[5m])) > 0",
          "legendFormat": "{{pod}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 12,
      "title": "Available Replicas vs Desired",
      "type": "timeseries",
      "description": "Gap between lines = pods not ready",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "desired",
          "expr": "sum(kube_deployment_spec_replicas{namespace=\"$namespace\"})",
          "legendFormat": "desired",
          "instant": false,
          "range": true
        },
        {
          "refId": "available",
          "expr": "sum(kube_deployment_status_replicas_available{namespace=\"$namespace\"})",
          "legendFormat": "available",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "desired"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "gray",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    8,
                    4
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "available"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 13,
      "title": "Node Disk I/O",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "read",
          "expr": "rate(node_disk_read_bytes_total[2m])",
          "legendFormat": "read",
          "instant": false,
          "range": true
        },
        {
          "refId": "write",
          "expr": "rate(node_disk_written_bytes_total[2m])",
          "legendFormat": "write",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "write"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "read"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 14,
      "title": "Node Network I/O",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 30,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "rx",
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|flannel.*|cni.*\"}[2m])",
          "legendFormat": "rx {{device}}",
          "instant": false,
          "range": true
        },
        {
          "refId": "tx",
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|flannel.*|cni.*\"}[2m])",
          "legendFormat": "tx {{device}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 15,
      "title": "Container Memory Usage % of Limit",
      "type": "timeseries",
      "description": "Working set memory as % of container limit \u2014 100% = OOM kill territory",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "banking-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(\n  sum by (container) (\n    container_memory_working_set_bytes{namespace=\"$namespace\", container!=\"\", container!=\"POD\"}\n  )\n  /\n  sum by (container) (\n    container_memory_limit_bytes{namespace=\"$namespace\", container!=\"\", container!=\"POD\"} > 0\n  )\n)",
          "legendFormat": "{{container}}",
          "instant": false,
          "range": true
        }
      ],
